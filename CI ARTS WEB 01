<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CI ARTS | Film Director</title>
    <meta name="description" content="CI ARTS — Visual storytelling and premium film production.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Cormorant for ultra-luxury headings, Inter for razor-sharp tech UI -->
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
    <style>
        /* ===== DESIGN TOKENS: LUXURY CINEMATIC ===== */
        :root {
            --bg: #050505;
            /* Deep Obsidian Black */
            --bg-glass: rgba(5, 5, 5, 0.7);
            --text: #FFFFFF;
            --text-dim: #888888;
            --text-muted: #444444;
            --ease: cubic-bezier(0.25, 1, 0.5, 1);
            --ease-heavy: cubic-bezier(0.7, 0, 0.3, 1);
        }

        /* ===== RESET & BASE ===== */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        a,
        button {
            text-decoration: none;
            color: inherit;
            border: none;
            background: none;
            cursor: pointer;
        }

        img {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* ===== TYPOGRAPHY ===== */
        h1,
        h2,
        h3,
        .t-display {
            font-family: 'Cormorant Garamond', Georgia, serif;
            font-weight: 300;
        }

        .t-sub {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-weight: 400;
            color: var(--text-dim);
        }

        /* ===== NAV ===== */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 2rem 4%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
            background: linear-gradient(to bottom, rgba(5, 5, 5, 0.8) 0%, transparent 100%);
            mix-blend-mode: difference;
            /* Extremely high-end fashion effect */
        }

        .logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.8rem;
            font-weight: 500;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .nav-links {
            display: flex;
            gap: 4rem;
            list-style: none;
        }

        .nav-links a {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--text);
            transition: opacity 0.4s;
        }

        .nav-links a:hover {
            opacity: 0.5;
        }

        /* ===== HERO ===== */
        @keyframes slowPan {
            0% {
                transform: scale(1.0);
            }

            100% {
                transform: scale(1.15);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .film-grain {
            position: absolute;
            inset: 0;
            z-index: 10;
            pointer-events: none;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.08;
            mix-blend-mode: overlay;
        }

        .hero {
            position: relative;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .hero-video {
            position: absolute;
            inset: 0;
            z-index: 0;
            overflow: hidden;
            background: #000;
        }

        .hero-fallback {
            position: absolute;
            inset: 0;
            width: 100vw;
            height: 100vh;
            object-fit: cover;
            opacity: 0.35;
            z-index: 1;
            transition: opacity 3s cubic-bezier(0.25, 1, 0.5, 1);
            pointer-events: none;
        }

        .hero-fallback.hidden {
            opacity: 0;
        }

        #heroVideoPlayer {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 100vw;
            height: 56.25vw;
            min-height: 100vh;
            min-width: 177.77vh;
            transform: translate(-50%, -50%) scale(1.1);
            pointer-events: none;
            border: none;
            opacity: 0;
            filter: blur(30px);
            transition: opacity 4s cubic-bezier(0.25, 1, 0.5, 1), filter 4s cubic-bezier(0.25, 1, 0.5, 1), transform 4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        #heroVideoPlayer.is-playing {
            opacity: 0.35;
            filter: blur(0);
            transform: translate(-50%, -50%) scale(1);
        }

        .hero-video::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, var(--bg) 0%, rgba(5, 5, 5, 0) 50%, rgba(5, 5, 5, 0.4) 100%);
        }

        .hero-content {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .hero-title {
            font-size: clamp(4rem, 12vw, 10rem);
            margin-bottom: 1rem;
            line-height: 1;
        }

        /* ===== WORK GALLERY ===== */
        .work-section {
            padding: 8rem 4%;
            max-width: 2000px;
            margin: 0 auto;
        }

        .work-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 6rem;
            border-bottom: 1px solid var(--text-muted);
            padding-bottom: 2rem;
        }

        .work-header h2 {
            font-size: clamp(3rem, 6vw, 5rem);
        }

        .work-filter {
            display: flex;
            gap: 3rem;
        }

        .work-filter button {
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-dim);
            transition: color 0.4s;
            position: relative;
        }

        .work-filter button:hover {
            color: var(--text);
        }

        .work-filter button.active {
            color: var(--text);
        }

        .work-filter button.active::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 100%;
            height: 1px;
            background: var(--text);
        }

        .work-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 6rem 4rem;
        }

        .work-tile {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            text-decoration: none;
            position: relative;
        }

        .work-tile.full-width {
            grid-column: span 2;
        }

        .tile-media {
            width: 100%;
            aspect-ratio: 21/9;
            position: relative;
            overflow: hidden;
            background: var(--text-muted);
        }

        .tile-media::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at center, transparent 30%, rgba(0, 0, 0, 0.8) 120%);
            opacity: 0.8;
            transition: opacity 1.5s ease;
            pointer-events: none;
        }

        .work-tile:hover .tile-media::after {
            opacity: 0.2;
        }

        .tile-media img {
            transition: transform 2.5s cubic-bezier(0.25, 1, 0.5, 1), filter 1.5s ease;
            filter: brightness(0.5) contrast(1.2) saturate(0.3);
        }

        .work-tile:hover .tile-media img {
            transform: scale(1.08);
            filter: brightness(1.05) contrast(1.1) saturate(1.1);
        }

        .tile-play {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.8);
            width: 80px;
            height: 80px;
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
            background: rgba(0, 0, 0, 0.2);
            opacity: 0;
            transition: all 0.8s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .tile-play svg {
            width: 16px;
            height: 16px;
            fill: var(--text);
            margin-left: 4px;
            transition: transform 0.5s ease;
        }

        .work-tile:hover .tile-play {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
            box-shadow: 0 0 40px rgba(255, 255, 255, 0.1);
        }

        .work-tile:hover .tile-play:hover svg {
            transform: scale(1.15);
        }

        .tile-info {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .tile-info h3 {
            font-size: 2rem;
            color: var(--text);
        }

        /* ===== EXPERIENCE ===== */
        .manifesto {
            padding: 8rem 4%;
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .manifesto h2 {
            font-size: clamp(3rem, 6vw, 5rem);
            margin-bottom: 2rem;
        }

        .manifesto p {
            font-family: 'Inter', sans-serif;
            font-size: 1.2rem;
            font-weight: 300;
            line-height: 1.8;
            color: var(--text-dim);
        }

        .experience-section {
            padding: 4rem 4% 8rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ===== CREDITS TICKER ===== */
        .credits-section {
            padding: 2rem 0 8rem;
            overflow: hidden;
            background: transparent;
            width: 100%;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .credits-track {
            display: flex;
            width: max-content;
            animation: ticker 60s linear infinite;
        }

        .credits-track:hover {
            animation-play-state: paused;
        }

        .credits-content {
            display: flex;
            flex-shrink: 0;
            gap: 4rem;
            padding-right: 4rem;
            white-space: nowrap;
            align-items: center;
        }

        .credit-item {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            transition: opacity 0.4s;
        }

        .credit-item:hover {
            opacity: 1;
        }

        .credits-track:hover .credit-item:not(:hover) {
            opacity: 0.3;
        }

        .credit-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 400;
            color: var(--text);
            font-style: italic;
        }

        .credit-role {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-dim);
        }

        .credit-sep {
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.15);
        }

        .imdb-btn-wrap {
            text-align: center;
            margin-top: 4rem;
        }

        .imdb-btn {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--text);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 1rem 3rem;
            border-radius: 50px;
            transition: all 0.4s var(--ease);
            text-decoration: none;
        }

        .imdb-btn:hover {
            background: #fff;
            color: #000;
            border-color: #fff;
        }

        /* ===== CONTACT ===== */
        .contact-section {
            padding: 12rem 4%;
            text-align: center;
        }

        .contact-sub {
            margin-bottom: 2rem;
            display: block;
        }

        .contact-email {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 8vw, 8rem);
            color: var(--text);
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            cursor: pointer;
            transition: opacity 0.4s var(--ease);
        }

        .contact-email:hover {
            opacity: 0.9;
        }

        .contact-email::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: var(--text);
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.8s var(--ease-heavy);
        }

        .contact-email:hover::after {
            transform: scaleX(1);
            transform-origin: left;
        }

        .contact-arrow {
            font-family: 'Inter', sans-serif;
            font-size: clamp(1.5rem, 3vw, 4rem);
            font-weight: 300;
            opacity: 0;
            transform: translateX(-20px) translateY(10px);
            transition: all 0.6s var(--ease-heavy);
        }

        .contact-email:hover .contact-arrow {
            opacity: 1;
            transform: translateX(0) translateY(0);
        }

        #emailText {
            transition: opacity 0.4s var(--ease);
        }

        /* ===== FOOTER ===== */
        footer {
            padding: 4rem 4%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .footer-social {
            display: flex;
            gap: 3rem;
        }

        .footer-social a {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-dim);
            transition: color 0.4s;
        }

        .footer-social a:hover {
            color: var(--text);
        }

        /* ===== TICKER ===== */
        .ticker-section {
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding: 2.5rem 0;
            overflow: hidden;
            background: transparent;
            width: 100%;
        }

        .ticker-wrap {
            overflow: hidden;
            display: flex;
            width: 100%;
        }

        .ticker-track {
            display: flex;
            width: max-content;
            animation: ticker 40s linear infinite;
        }

        .ticker-content {
            display: flex;
            flex-shrink: 0;
            gap: 4rem;
            padding-right: 4rem;
            white-space: nowrap;
            align-items: center;
        }

        .ticker-item {
            font-family: 'Inter', sans-serif;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--text-dim);
            opacity: 0.6;
        }

        @keyframes ticker {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        /* ===== VIDEO MODAL (LUXURY) ===== */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.96);
            z-index: 9000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.6s var(--ease-heavy);
            backdrop-filter: blur(10px);
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-close {
            position: absolute;
            top: 2rem;
            right: 3rem;
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--text);
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 1rem;
            z-index: 9001;
        }

        .modal-content {
            width: 92vw;
            max-width: 1600px;
            aspect-ratio: 16/9;
            background: #000;
            transform: scale(0.95);
            transition: transform 0.8s var(--ease-heavy);
            position: relative;
        }

        .modal-overlay.active .modal-content {
            transform: scale(1);
        }

        .modal-content iframe,
        #plyrContainer {
            width: 100%;
            height: 100%;
            border: none;
        }

        /* Plyr customizations */
        :root {
            --plyr-color-main: #ffffff;
            --plyr-video-background: #000000;
        }

        .plyr--video .plyr__controls {
            background: linear-gradient(rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.7));
            padding: 20px;
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.96);
            z-index: 9000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            visibility: hidden;
            transition: all 0.6s var(--ease-heavy);
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            width: 92vw;
            max-width: 1600px;
            aspect-ratio: 21/9;
            background: #000;
            transform: scale(0.95);
            transition: transform 0.8s var(--ease-heavy);
            position: relative;
        }

        .modal-overlay.active .modal-content {
            transform: scale(1);
        }

        .modal-content iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

        .modal-close {
            position: fixed;
            top: 2.5rem;
            right: 4%;
            background: none;
            color: var(--text-dim);
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            font-weight: 400;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            cursor: pointer;
            z-index: 9001;
            transition: color 0.3s;
        }

        .modal-close:hover {
            color: var(--text);
        }

        /* ===== MOBILE MENU ===== */
        .menu-toggle {
            display: none;
            width: 30px;
            height: 14px;
            position: relative;
            z-index: 200;
        }

        .menu-toggle span {
            display: block;
            width: 100%;
            height: 1px;
            background: var(--text);
            position: absolute;
            left: 0;
            transition: all 0.4s var(--ease);
        }

        .menu-toggle span:nth-child(1) {
            top: 0;
        }

        .menu-toggle span:nth-child(2) {
            bottom: 0;
        }

        .menu-toggle.active span:nth-child(1) {
            top: 50%;
            transform: rotate(45deg);
        }

        .menu-toggle.active span:nth-child(2) {
            top: 50%;
            transform: rotate(-45deg);
        }

        .mobile-menu {
            position: fixed;
            inset: 0;
            background: rgba(5, 5, 5, 0.85);
            backdrop-filter: blur(25px);
            z-index: 150;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3rem;
            opacity: 0;
            visibility: hidden;
            transition: all 0.6s var(--ease-heavy);
        }

        .mobile-menu.active {
            opacity: 1;
            visibility: visible;
        }

        .mobile-link {
            font-family: 'Cormorant Garamond', serif;
            font-size: 3rem;
            color: var(--text);
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.6s var(--ease-heavy);
        }

        .mobile-menu.active .mobile-link {
            opacity: 1;
            transform: translateY(0);
        }

        .mobile-menu.active .mobile-link:nth-child(1) {
            transition-delay: 0.1s;
        }

        .mobile-menu.active .mobile-link:nth-child(2) {
            transition-delay: 0.2s;
        }

        .mobile-menu.active .mobile-link:nth-child(3) {
            transition-delay: 0.3s;
        }

        /* ===== REVEAL ===== */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 1.2s var(--ease-heavy), transform 1.2s var(--ease-heavy);
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 1024px) {
            .work-grid {
                gap: 4rem 2rem;
            }
        }

        @media (max-width: 768px) {
            nav {
                mix-blend-mode: normal;
            }

            .nav-links {
                display: none;
            }

            .menu-toggle {
                display: block;
            }

            .work-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 2rem;
            }

            .work-grid {
                grid-template-columns: 1fr;
                gap: 4rem;
            }

            .work-tile.full-width {
                grid-column: span 1;
            }

            .experience-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }

            footer {
                flex-direction: column;
                gap: 2rem;
                text-align: center;
            }
        }

        /* ===== CUSTOM CURSOR ===== */
        .custom-cursor {
            position: fixed;
            top: 0;
            left: 0;
            pointer-events: none;
            z-index: 9999;
            width: 10px;
            height: 10px;
            background: var(--text);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: width 0.4s var(--ease-heavy), height 0.4s var(--ease-heavy), background 0.4s, border 0.4s;
            mix-blend-mode: difference;
        }

        .custom-cursor .cursor-text {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.2em;
            opacity: 0;
            transition: opacity 0.3s;
            color: var(--text);
        }

        .custom-cursor.play-mode {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            mix-blend-mode: normal;
        }

        .custom-cursor.play-mode .cursor-text {
            opacity: 1;
        }

        @media (hover: hover) and (pointer: fine) {

            body,
            a,
            button,
            .work-tile,
            .contact-email {
                cursor: none !important;
            }
        }
    </style>
</head>

<body>

    <!-- CUSTOM CURSOR -->
    <div class="custom-cursor" id="customCursor">
        <span class="cursor-text">PLAY</span>
    </div>

    <!-- NAV -->
    <nav>
